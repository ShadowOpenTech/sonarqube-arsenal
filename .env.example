# ── Shared ────────────────────────────────────────────────────────────────────
SONAR_URL=http://sonarqube.example.com
SONAR_CONCURRENCY=10

# ── sonar_security_report.py ──────────────────────────────────────────────────
SONAR_USERNAME=admin
SONAR_PASSWORD=secret
SONAR_LIMIT=0
SONAR_OUTPUT=sonar_report.json
SONAR_EXCEL=sonar_report.xlsx

# ── sonar_reopen_vulnerabilities.py ───────────────────────────────────────────
# SONAR_USERNAME and SONAR_PASSWORD are shared with sonar_security_report.py
SONAR_PROJECTS_FILE=projects.txt
SONAR_REOPEN_OUTPUT=reopen_report.xlsx

# ── sonar_propagate_status.py ─────────────────────────────────────────────────
# SONAR_USERNAME, SONAR_PASSWORD, SONAR_URL, SONAR_CONCURRENCY shared above
SONAR_PROJECT=
SONAR_SOURCE_BRANCH=
SONAR_PROPAGATE_OUTPUT=propagate_report.xlsx

# ── sonar_trend/ suite ────────────────────────────────────────────────────────
# SONAR_USERNAME, SONAR_PASSWORD, SONAR_URL, SONAR_CONCURRENCY shared above
# sonar_branch_select.py
SONAR_BRANCH_CACHE=sonar_trend/branch_selection.json
SONAR_BRANCH_EXCEL=sonar_trend/branch_selection_report.xlsx
# sonar_trend_snapshot.py
SONAR_SNAPSHOTS_DIR=sonar_trend/snapshots
SONAR_SNAPSHOTS_RETAIN=52
# sonar_trend_report.py
SONAR_DEPT_MAPPING=sonar_trend/dept_mapping.csv
SONAR_TREND_OUTPUT=sonar_trend/trend_report.xlsx
SONAR_SNAPSHOTS_COUNT=52
